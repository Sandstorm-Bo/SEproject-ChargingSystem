<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.charging.station.mapper.PileMapper">

    <!-- Result Map -->
    <resultMap id="ChargingPileResultMap" type="com.charging.station.domain.ChargingPile">
        <id property="pileId" column="pile_id"/>
        <result property="pileNo" column="pile_no"/>
        <result property="pileType" column="pile_type"/>
        <result property="status" column="status"/>
        <result property="ratedPower" column="rated_power"/>
        <result property="queueCapacityM" column="queue_capacity_m"/>
        <result property="isWorking" column="is_working"/>
        <result property="totalChargeCount" column="total_charge_count"/>
        <result property="totalChargeDuration" column="total_charge_duration"/>
        <result property="totalChargeAmount" column="total_charge_amount"/>
        <result property="isSchedulable" column="is_schedulable"/>
        <result property="faultReason" column="fault_reason"/>
        <result property="lastRunTime" column="last_run_time"/>
        <result property="lastStopTime" column="last_stop_time"/>
    </resultMap>

    <!-- 查询单个充电桩 -->
    <select id="getPile" resultMap="ChargingPileResultMap">
        SELECT * FROM charging_pile
        WHERE pile_id = #{pileId}
    </select>

    <!-- 查询所有充电桩 -->
    <select id="getAllChargingPiles" resultMap="ChargingPileResultMap">
        SELECT * FROM charging_pile
        ORDER BY pile_no
    </select>

    <!-- 查询所有充电桩（别名） -->
    <select id="selectAllPiles" resultMap="ChargingPileResultMap">
        SELECT * FROM charging_pile
        ORDER BY pile_no
    </select>

    <!-- 更新充电桩状态 -->
    <update id="updatePileState">
        UPDATE charging_pile
        SET status = #{status},
            is_working = #{isWorking},
            total_charge_count = #{totalChargeCount},
            total_charge_duration = #{totalChargeDuration},
            total_charge_amount = #{totalChargeAmount},
            is_schedulable = #{isSchedulable},
            fault_reason = #{faultReason},
            last_run_time = #{lastRunTime},
            last_stop_time = #{lastStopTime}
        WHERE pile_id = #{pileId}
    </update>

    <!-- 插入充电桩 -->
    <insert id="insertPile">
        INSERT INTO charging_pile (
            pile_id, pile_no, pile_type, status, rated_power,
            queue_capacity_m, is_schedulable
        ) VALUES (
            #{pileId}, #{pileNo}, #{pileType}, #{status}, #{ratedPower},
            #{queueCapacityM}, #{isSchedulable}
        )
    </insert>

</mapper>
